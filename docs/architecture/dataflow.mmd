graph TB
    subgraph inputs["Tool Calls"]
        Bash["Bash"]
        Write["Write / Edit"]
        Read["Read"]
        Glob["Glob / Grep"]
    end
    subgraph scanning["Scanning Layer"]
        secrets["secret-scanner<br/><small>R1: Aho-Corasick + R2: Shannon Entropy</small>"]
        vulns["vuln-detector<br/><small>R3: OWASP Graph</small>"]
        guard["action-guard<br/><small>R4: Markov + R7: Overflow (advisory)</small>"]
    end
    subgraph advisory["Advisory Layer (added 2026-05-05)"]
        pkg["package-gate<br/><small>5 risk signals on install verbs</small>"]
        egress["egress-monitor<br/><small>WebFetch / WebSearch / Bash-network destinations</small>"]
        cnry["canary<br/><small>Prompt-injection canary tokens + leak scan</small>"]
        fence["capability-fence<br/><small>Subagent-escape detection vs allowed-tools</small>"]
    end
    Write --> secrets
    Write --> vulns
    Bash --> guard
    Bash --> pkg
    Bash --> egress
    Bash --> fence
    Read --> fence
    Glob --> fence
    Write --> fence
    Read --> cnry
    Write --> cnry
    subgraph state["State Layer"]
        audit["audit-trail/state/audit.jsonl"]
        metrics["*/state/metrics.jsonl"]
        learnings["*/state/learnings.json"]
    end
    secrets --> audit
    vulns --> audit
    guard --> audit
    pkg --> audit
    egress --> audit
    cnry --> audit
    fence --> audit
    Read --> audit_hook["audit-trail"]
    Glob --> audit_hook
    audit_hook --> audit
    subgraph output["Output"]
        report["📊 /hydra:audit<br/>Security Report"]
    end
    audit --> report
    metrics --> report
    learnings --> report
