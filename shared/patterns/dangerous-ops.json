    "id": "git-push-protected-branch",
    "pattern": "git\\s+push\\s+.*(?:origin|upstream)\\s+(?:main|master|production|release|develop)(?:\\s|$)",
    "severity": "medium",
    "category": "git",
    "action": "warn",
    "description": "Pushing directly to protected branch — use pull request workflow"
  },
  {
    "id": "git-rebase-main",
    "pattern": "git\\s+rebase\\s+.*(?:main|master|production|release)(?:\\s|$)",
    "severity": "medium",
    "category": "git",
    "action": "warn",
    "description": "Rebasing onto protected branch — may rewrite shared history"
  },
  {
    "id": "modify-ci-config",
    "pattern": "(?:>|tee|cp|mv|sed|vim|nano|code)\\s+.*(?:\\.github/workflows/|\\.gitlab-ci\\.yml|\\.circleci/|Jenkinsfile|azure-pipelines\\.yml|\\.travis\\.yml)",
    "severity": "high",
    "category": "supply-chain",
    "action": "warn",
    "description": "Modifying CI/CD configuration — pipeline tampering risk"
  },
  {
    "id": "npm-install-global-untrusted",
    "pattern": "npm\\s+(?:install|i)\\s+(?:-g|--global)\\s+(?!@types/|typescript|npm|yarn|pnpm|eslint|prettier)",
    "severity": "medium",
    "category": "supply-chain",
    "action": "warn",
    "description": "Global npm install — runs install scripts with user privileges"
  },
  {
    "id": "pip-install-force",
    "pattern": "pip\\s+install\\s+--(?:no-deps|force-reinstall|ignore-installed|break-system-packages)",
    "severity": "medium",
    "category": "supply-chain",
    "action": "warn",
    "description": "pip install with safety bypass flags — dependency risk"
  },
  {
    "id": "gem-install-no-check",
    "pattern": "gem\\s+install\\s+.*--no-verify",
    "severity": "high",
    "category": "supply-chain",
    "action": "warn",
    "description": "Ruby gem install without verification — supply chain risk"
  },
  {
    "id": "npm-config-registry",
    "pattern": "npm\\s+(?:config\\s+set|set)\\s+registry\\s+(?!https://registry\\.npmjs\\.org)",
    "severity": "high",
    "category": "supply-chain",
    "action": "warn",
    "description": "Changing npm registry to non-default — supply chain risk"
  },
  {
    "id": "gcloud-project-delete",
    "pattern": "gcloud\\s+projects?\\s+delete",
    "severity": "critical",
    "category": "infrastructure",
    "action": "block",
    "description": "GCP project deletion — destroys all resources in project"
  },
  {
    "id": "gcloud-iam-policy",
    "pattern": "gcloud\\s+(?:iam|projects)\\s+(?:set-iam-policy|add-iam-policy-binding).*(?:allUsers|allAuthenticatedUsers)",
    "severity": "critical",
    "category": "infrastructure",
    "action": "block",
    "description": "GCP IAM public access — exposes resources to everyone"
  },
  {
    "id": "az-group-delete",
    "pattern": "az\\s+group\\s+delete",
    "severity": "critical",
    "category": "infrastructure",
    "action": "block",
    "description": "Azure resource group deletion — destroys all resources in group"
  },
  {
    "id": "helm-delete-purge",
    "pattern": "helm\\s+(?:delete|uninstall)\\s+.*(?:--purge|--no-hooks)",
    "severity": "high",
    "category": "infrastructure",
    "action": "warn",
    "description": "Helm release deletion with purge — removes release history"
  },
  {
    "id": "etcdctl-delete",
    "pattern": "etcdctl\\s+(?:del|delete)\\s+.*(?:--prefix|/)",
    "severity": "critical",
    "category": "data",
    "action": "block",
    "description": "etcd prefix deletion — may destroy cluster state"
  },
  {
    "id": "ssh-add-wildcard",
    "pattern": "ssh-add\\s+(?:-D|--delete-all)",
    "severity": "medium",
    "category": "crypto",
    "action": "warn",
    "description": "Removing all SSH keys from agent — may break SSH access"
  },
  {
    "id": "gpg-delete-keys",
    "pattern": "gpg\\s+--delete-(?:secret-)?keys",
    "severity": "high",
    "category": "crypto",
    "action": "warn",
    "description": "Deleting GPG keys — may lose ability to decrypt data"
  },
  {
    "id": "dd-if-dev-zero",
    "pattern": "dd\\s+if=/dev/(?:zero|urandom)\\s+of=(?!/dev/null)",
    "severity": "critical",
    "category": "filesystem",
    "action": "block",
    "description": "Writing zeros/random to device/file — data destruction"
  },
  {
    "id": "history-clear",
    "pattern": "(?:history\\s+-c|>\\s*~/?\\.(?:bash_history|zsh_history)|HISTSIZE=0|unset\\s+HISTFILE)",
    "severity": "medium",
    "category": "system",
    "action": "warn",
    "description": "Clearing/disabling shell history — anti-forensics"
  },
  {
    "id": "nc-listen",
    "pattern": "(?:nc|ncat|netcat)\\s+.*-l\\s*.*-p",
    "severity": "medium",
    "category": "network",
    "action": "warn",
    "description": "Netcat listener — potential backdoor"
  },
  {
    "id": "scp-to-external",
    "pattern": "scp\\s+.*(?:/etc/|/var/|~/).*@(?!localhost|127\\.0\\.0\\.1)",
    "severity": "medium",
    "category": "exfiltration",
    "action": "warn",
    "description": "SCP sensitive files to external host — data exfiltration risk"
  },
  {
    "id": "aws-s3-public-acl",
    "pattern": "aws\\s+s3(?:api)?\\s+(?:put-bucket-acl|put-object-acl).*(?:public-read|public-read-write|authenticated-read)",
    "severity": "critical",
    "category": "infrastructure",
    "action": "block",
    "description": "AWS S3 public ACL — exposes data to the internet"
  },
  {
    "id": "docker-exec-root",
    "pattern": "docker\\s+exec\\s+.*(?:-u\\s+root|--user\\s+root)",
    "severity": "medium",
    "category": "infrastructure",
    "action": "warn",
    "description": "Docker exec as root — elevated container privileges"
  },
  {
    "id": "npm-audit-fix-force",
    "pattern": "npm\\s+audit\\s+fix\\s+--force",
    "severity": "medium",
    "category": "supply-chain",
    "action": "warn",
    "description": "npm audit fix --force — may install breaking major version changes"
  },
  {
    "id": "base64-decode-exec",
    "pattern": "(?:echo|printf)\\s+['\\\"]?[A-Za-z0-9+/=]{40,}['\\\"]?\\s*\\|\\s*base64\\s+(?:-d|--decode)\\s*\\|\\s*(?:bash|sh|zsh|python|ruby|perl)",
    "severity": "critical",
    "category": "network",
    "action": "block",
    "description": "Base64-encoded payload piped to base64 -d and executed — common obfuscation for hostile shell commands."
  },
  {
    "id": "npx-untrusted-direct",
    "pattern": "\\bnpx\\s+(?!(?:--yes\\s+)?(?:@anthropic-ai/|@enchanted-plugins/|@modelcontextprotocol/))[a-zA-Z0-9@_/.-]+\\s",
    "severity": "high",
    "category": "network",
    "action": "warn",
    "description": "npx execution of a package outside the trusted scope (@anthropic-ai, @enchanted-plugins, @modelcontextprotocol). Verify package provenance."
  },
  {
    "id": "uvx-untrusted-direct",
    "pattern": "\\buvx\\s+(?!--from\\s+git\\+https://github\\.com/(?:anthropics|enchanted-plugins)/)[a-zA-Z0-9@_/.-]+\\s",
    "severity": "high",
    "category": "network",
    "action": "warn",
    "description": "uvx execution of a package outside trusted GitHub orgs (anthropics, enchanted-plugins). Verify provenance."
  },
  {
    "id": "claude-mcp-add-untrusted-launcher",
    "pattern": "claude\\s+mcp\\s+add\\s+\\S+\\s+(?:npx|uvx|pnpm\\s+dlx)\\s+",
    "severity": "critical",
    "category": "network",
    "action": "block",
    "description": "Direct 'claude mcp add' of an arbitrary package via npx/uvx/pnpm dlx launcher — MCP supply chain exposure. Verify server identity first."
  },
  {
    "id": "claude-plugin-install-untrusted",
    "pattern": "(?:claude(?:-code)?\\s+)?/?plugin\\s+install\\s+(?!\\S*@(?:enchanted-plugins|anthropic|anthropics))\\S+@\\S+",
    "severity": "high",
    "category": "network",
    "action": "warn",
    "description": "Claude Code plugin install from an untrusted marketplace (not enchanted-plugins or anthropic). Verify maintainer + marketplace.json integrity."
  },
  {
    "id": "mcp-inspector-http-unencrypted",
    "pattern": "@modelcontextprotocol/inspector[^\\n]*--transport\\s+http\\s+http://(?!localhost|127\\.0\\.0\\.1)",
    "severity": "high",
    "category": "network",
    "action": "warn",
    "description": "MCP inspector using unencrypted http:// transport to a non-local host — credentials in transit."
  },
  {
    "id": "git-clone-then-exec-chain",
    "pattern": "git\\s+clone\\s+[^&;|]+(?:&&|;)\\s*(?:cd\\s+\\S+\\s*(?:&&|;)\\s*)?(?:curl|wget|bash|sh|make|npm\\s+(?:i|install)|pip\\s+install)",
    "severity": "high",
    "category": "network",
    "action": "warn",
    "description": "Clone-then-execute compound chain — clones untrusted repo and immediately runs code from it. Classic supply-chain attack surface."
  },
  {
    "id": "hooks-install-write-local",
    "pattern": "(?:echo|cat|tee|printf)[^\\n]*>\\s*\\.claude/settings(?:\\.local)?\\.json",
    "severity": "high",
    "category": "filesystem",
    "action": "warn",
    "description": "Direct Bash write to .claude/settings.json or settings.local.json bypasses hook-manifest review. Settings changes should go through /plugin install."
  }
]
