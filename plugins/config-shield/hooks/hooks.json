{
  "description": "Reaper config-shield: scans repository config files at session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start/scan-config.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
