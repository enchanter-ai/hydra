{
  "description": "Hydra secret-scanner: scans Write/Edit output for 200+ secret patterns",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use/scan-secrets.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
