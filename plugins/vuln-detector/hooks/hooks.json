{
  "description": "Reaper vuln-detector: scans Write/Edit output for OWASP Top 10 vulnerabilities",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use/detect-vuln.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
