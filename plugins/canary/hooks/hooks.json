{
  "description": "Hydra canary: PreToolUse(WebFetch) seeds a per-session canary token; PostToolUse(*) scans tool inputs/outputs for leakage. Always exit 0.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-webfetch.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-scan.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
