{
  "description": "Hydra action-guard: classifies and blocks dangerous Bash commands",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use/guard-action.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
